int main(){
    State current_state=STATE_MENU;
    char input;

    while(1){
        switch(current_state){
            case STATE_MENU:
                TitleBanner();
                printf("Welcome to the Main Menu!\n");
                printf("Press '1' to Start the Game: ");
                printf("Press 'q' to Quit the Game: ");
                scanf(" %c", &input);
                if (input=='1') current_state=STATE_CHAR;
                else if (input=='q') return 0;
                break;

            case STATE_CHAR:
                printf("Enter your character name: ");
                scanf("%19s", player.name);
                printf("Select Difficulty (0 = Easy, 1 = Hard): ");
                scanf(" %d", &player.difficulty);
                current_state=STATE_EXPLORE;
                break;

            case STATE_EXPLORE:
                printf("You are currently in Room %c\n", player.room == 0 ? 'A' : 'B');
                if (player.room==0){

                    printf("You are in Room A. There is a door on the right leading to Room B.\n");
                    printf("Press 'm' to view the map, 'n' to move to Room B, 'p' to attempt a puzzle: ");
                }
                else{

                    printf("You are in Room B. There is a door on the left leading to Room A.\n");
                    printf("Press 'm' to view the map, 'n' to move to Room A, 'p' to attempt a puzzle: ");
                }
                scanf(" %c", &input);
                if (input=='m') Map();
                else if (input=='n') player.room = !player.room;
                else if(input=='p'){
                    if(player.room==1){
                            if (player.collected_cards==0){
                                printf("-----PUZZLE 1------\n");
                                printf("BEGIN PUZZLE 1? (y/n): ");
                                scanf(" %c", &input);
                                if (input=='y'||input=='Y'){
                                    //start puzzle 1 logic here
                                    if (player.difficulty==0){
                                        printf("Riddle: What is the 4 bit conguration of value 1?\n");
                                    }
                                    else if (player.difficulty==1){
                                        printf("Riddle: What is the 4 bit configuration of value 8?\n");
                                    }

                                    if (AttemptCount(puzzle_bitmaster, player.difficulty)){
                                        printf("\n");
                                        printf("├────*─────*────*────┤\n");
                                        printf("├     *    *     *   ┤\n");
                                        printf("├  KeyCard 1 * *  * ┤\n");
                                        printf("├      *     *     *┤\n");
                                        printf("├───────*─────*─────*┤\n");
                                        printf("Puzzle 1 Solved! Card collected!\n");
                                        printf("\n");
                                        player.collected_cards++;
                                    }
                                }
                                else{
                                    printf("Returning to exploration...\n");
                                }
                            }
                            else if (player.collected_cards==1){
                                printf("-----PUZZLE 2------\n");
                                printf("BEGIN PUZZLE 2? (y/n): ");
                                scanf(" %c", &input);
                                if (input=='y'||input=='Y'){
                                    //start puzzle 2 logic here
                                    if (player.difficulty==0){
                                        printf("What is 3*12?\n");
                                    }                                        
                                    else if (player.difficulty==1){
                                        printf("What is 8*12?\n");
                                    }

                                    if (AttemptCount(puzzle_mathriddle, player.difficulty)){
                                        printf("\n");
                                        printf("├────*─────*────*────┤\n");
                                        printf("├     *    *     *   ┤\n");
                                        printf("├  KeyCard 2 * *  * ┤\n");
                                        printf("├      *     *     *┤\n");
                                        printf("├───────*─────*─────*┤\n");
                                        printf("\n");
                                        printf("Puzzle 2 Solved! Card collected!\n");
                                        player.collected_cards++;
                                    }
                                }
                                else{
                                    printf("Returning to exploration...\n");
                                }
                            }
                            else if (player.collected_cards==2){
                                printf("-----PUZZLE 3------\n");
                                printf("BEGIN PUZZLE 3? (y/n): ");
                                scanf(" %c", &input);
                                if (input=='y'||input=='Y'){
                                    //start puzzle 3 logic here
                                    printf("What is the password to escape?\n");
                                    printf("Hint: The password is a 4 digit number with alternating zero values.\n");
                                    printf("The desired PIN will have the same repeated first digit\n");
                                    printf("Select any value from 1 to 9\n");
                                    printf("Example: '_0_0'\n");
                                    
                                    if (AttemptCount(puzzle_password, player.difficulty)){
                                        printf("\n");
                                        printf("├────*─────*────*────┤\n");
                                        printf("├     *    *     *   ┤\n");
                                        printf("├  KeyCard 3 * *  * ┤\n");
                                        printf("├      *     *     *┤\n");
                                        printf("├───────*─────*─────*┤\n");
                                        printf("\n");
                                        printf("Puzzle 3 Solved! Card collected!\n");
                                        player.collected_cards++;
                                        current_state=STATE_WIN;
                                    }
                                }
                                else{
                                    printf("Returning to exploration...\n");
                                }
                            }
                            else{
                                printf("All puzzles completed! You can now escape!\n");
                                current_state=STATE_WIN;
                            }
                    }
                    else if(player.room==0){
                        printf("-----Invalid Input: Only use 'p' in Room B!------\n");
                    }
                }
                break;
        
            case STATE_WIN:
                printf("\n");
                printf("  db   db  .d88b.  db   db      db   d8b   db d888888b d8b   db db \n");
                printf("  `8b d8' .8P  Y8. 88   88      88   I8I   88   `88'   888o  88 88 \n");
                printf("   `8bd8'  88    88 88   88      88   I8I   88    88    88V8o 88 YP \n");
                printf("     88    88    88 88   88      Y8   I8I   88    88    88 V8o88    \n");
                printf("     88    `8b  d8' 88b  d88      `8b d8'8b d8'   .88.   88  V888 db \n");
                printf("     YP     `Y88P'  ~Y8888P'       `8b8' `8d8'  Y888888P VP   V8P YP \n");
                printf("\n");
                printf("You Have Won The Game, %s!\n", player.name);
                return 0;
        }
    }
    return 0;
}