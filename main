#include <stdio.h>
#include <string.h>
typedef enum{
    STATE_MENU,
    STATE_CHAR,
    STATE_EXPLORE, 
    STATE_WIN}State;

struct Player{
    char name[20];  // Player's name: string
    int difficulty; // Difficulty level: 0 for easy, 1 for hard : integer
    int room;       // Current position: 0 for Room A, 1 for Room B : integer
    int collected_cards;    // Counter for # of cards collected: integer
    int puzzle_attempts; // Counter for # of puzzle attempts: integer
} player={"", 0, 0, 0, 0};    // Initial player default values: (name, difficulty, room, collected_cards)

// Function handlew attempts based on difficulty
int AttemptCount(int (*puzzle_func)(int, int), int difficulty){
    int attempts = (difficulty == 0) ? 3 : 1;   // is dificulty true to zero, then attempts==3, else attempts==1
    int user_input;

    if (difficulty == 1){
        printf("[HARD MODE: You only get 1 attempt.]\n");
    }

    while (attempts > 0){
        if (difficulty == 0) {
            printf("[EASY MODE: %d attempt(s) remaining]\n", attempts);
        }

        printf("Enter integer value: ");
        scanf(" %d", &user_input);

        // Call the Assembly puzzle function
        if (puzzle_func(user_input, difficulty)) {
            return 1; // Completed
        }

        attempts--;
        if (attempts > 0) {
            printf("Incorrect answer! Try again.\n\n");
        }
    }

    printf("0 attempts remaining. Returning to exploration...\n");
    return 0; // Failed
}

//Establish the external Assembly function for the puzzles
extern int puzzle_bitmaster(int input, int difficulty);
extern int puzzle_mathriddle(int input, int difficulty);
extern int puzzle_password(int input, int difficulty);

void TitleBanner(){
    printf("\n");
    printf("  ███████ ███████  ██████  █████  ██████  ███████\n");
    printf("  ██      ██      ██      ██   ██ ██   ██ ██     \n");
    printf("  █████   ███████ ██      ███████ ██████  █████  \n");
    printf("  ██           ██ ██      ██   ██ ██      ██     \n");
    printf("  ███████ ███████  ██████ ██   ██ ██      ███████\n");
    printf("\n");
}

void Map(){
    printf("MAP\n");
    if (player.room==0){
        printf("[**Position: Room A] -------------- [Room B]\n");
        printf("  ██████████████████                        \n");
        printf("  ███├├├├├├├├├├├├███     ██████████████████ \n");
        printf("  █├├├├├    ├├├├├├├█     █┤┤┤┤┤┤┤┤┤┤┤┤┤┤┤██ \n");
        printf("  █├├ [**YOU] ├├├├├█     █┤┤┤┤┤┤┤┤┤┤┤┤┤┤███ \n");
        printf("  █├├├├├   ├├├├├├├├█     █┤┤┤┤ (ROOM B)┤███ \n");
        printf("  █├├├├├├├├├├├├├├████████┤┤┤┤┤┤┤┤┤┤┤┤┤┤┤┤██ \n");
        printf("  █├├├├├├├├├├├├├├████████┤┤┤┤┤┤[P]┤┤┤┤┤┤┤██ \n");
        printf("  █├├├├├├├├├├├├├├████████┤┤┤┤┤┤┤┤┤┤┤┤┤┤┤┤██ \n");
        printf("  █├├├├├├├├├├├├├├├├█     █┤┤┤┤┤┤┤┤┤┤┤┤┤┤███ \n");
        printf("  █├├├├├├├├├├├├├├├├█     █┤┤┤┤┤┤┤┤┤┤┤┤┤┤███ \n");
        printf("  █├├├├├├├├├├├├├├├├█     █┤┤┤┤┤┤┤┤┤┤┤┤┤┤┤██ \n");
        printf("  ██├├├├(ROOM A)├├├█     ██████████████████ \n");
        printf("   ██├├├├├├├├├├├├███                        \n");
        printf("     █████████████                          \n");
    }
    else{
        printf("[Room A] -------------- [**Position: Room B]\n");
        printf("  ██████████████████                        \n");
        printf("  ███├├├├├├├├├├├├███     ██████████████████ \n");
        printf("  █├├├├├├├├├├├├├├├├█     █┤┤┤┤┤┤┤┤┤┤┤┤┤┤┤██ \n");
        printf("  █├├├├├├├├├├├├├├├├█     █┤┤┤┤┤┤┤┤┤┤┤┤┤┤███ \n");
        printf("  █├├├├├├├├├├├├├├├├█     █┤┤┤┤┤(ROOM B)┤███ \n");
        printf("  █├├├├├├├├├├├├├├████████┤┤┤┤┤┤┤┤┤┤┤┤┤┤┤┤██ \n");
        printf("  █├├├├├├├├├├├├├├████████┤┤┤┤┤┤[P]┤┤┤┤┤┤┤██ \n");
        printf("  █├├├├├├├├├├├├├├████████┤┤┤┤┤┤┤┤┤┤┤┤┤┤┤┤██ \n");
